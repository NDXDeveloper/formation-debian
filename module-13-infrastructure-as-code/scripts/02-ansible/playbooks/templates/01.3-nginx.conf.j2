# Configuration Nginx gérée par Ansible — NE PAS MODIFIER MANUELLEMENT
# Hôte : {{ inventory_hostname }}
# Généré le : {{ ansible_date_time.iso8601 }}

user www-data;
worker_processes {{ nginx_worker_processes | default('auto') }};
pid /run/nginx.pid;
error_log /var/log/nginx/error.log {{ nginx_log_level | default('warn') }};

events {
    worker_connections {{ nginx_worker_connections | default(1024) }};
    multi_accept on;
}

http {
    sendfile on;
    tcp_nopush on;
    tcp_nodelay on;
    keepalive_timeout {{ nginx_keepalive_timeout | default(65) }};
    types_hash_max_size 2048;
    server_tokens off;

    include /etc/nginx/mime.types;
    default_type application/octet-stream;

    # Logging
    log_format main '$remote_addr - $remote_user [$time_local] '
                    '"$request" $status $body_bytes_sent '
                    '"$http_referer" "$http_user_agent"';

    access_log /var/log/nginx/access.log main;

    # Compression
{% if nginx_enable_gzip | default(true) %}
    gzip on;
    gzip_vary on;
    gzip_proxied any;
    gzip_comp_level {{ nginx_gzip_level | default(6) }};
    gzip_types text/plain text/css application/json application/javascript text/xml application/xml;
{% endif %}

{% if nginx_resolver is defined %}
    resolver {{ nginx_resolver | join(' ') }};
{% endif %}

    # Virtual hosts
    include /etc/nginx/conf.d/*.conf;
    include /etc/nginx/sites-enabled/*;
}
